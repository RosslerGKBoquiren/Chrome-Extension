{
    "manifest_version": 3,
    "version": "1.0",
    "name": "Leads tracker",
    "action": {
        "default_popup": "index.html"
    },
    "permissions": ["tabs"],
    "host_permissions": [
        "http://localhost:5173/*"
    ],
    "content_security_policy": {
        "extension_pages": "script-src 'self' http://localhost:5173; object-src 'self'"
    }
}